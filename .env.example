# Qdrant Cloud (Free Tier)
# Get from https://cloud.qdrant.io → Cluster → Overview
QDRANT_URL=https://your-cluster-xxxx.qdrant.io:6333
QDRANT_API_KEY=your_api_key_here

# Free Tier - Skip expensive APIs
USE_LOCAL_EMBEDDINGS=true

# GitHub Secrets names (no .env needed on CI)
# QDRANT_URL, QDRANT_API_KEY

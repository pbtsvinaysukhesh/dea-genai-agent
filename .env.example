# Copy this file to .env and fill in your own values
# DO NOT commit .env to version control

# Google/Gemini API Key
GOOGLE_API_KEY=your-google-api-key-here

# Groq API Key (for fast cloud LLM)
GROQ_API_KEY=your-groq-api-key-here

# Email Configuration
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-gmail-app-password

# Ollama Configuration
ENABLE_OLLAMA=true
OLLAMA_URL=http://localhost:11434

# Optional: Only set if using Docker or remote Ollama
# OLLAMA_URL=http://ollama:11434

# Application Settings
APP_ENV=development

# Logging
LOG_LEVEL=INFO

# Report Output Paths (optional, defaults shown)
REPORT_OUTPUT_DIR=results/reports
BACKUP_DIR=results/backup
PODCAST_DIR=results/podcasts

# Podcast Configuration
PODCAST_GREETING=Hello Every One Good Evening & Good morning Welcome to Vinay DEA podcast
# Optional: Paths to intro/outro music files (MP3 or WAV)
# PODCAST_INTRO_MUSIC_PATH=/path/to/intro.mp3
# PODCAST_OUTRO_MUSIC_PATH=/path/to/outro.mp3
